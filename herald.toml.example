# Herald configuration example
# Copy this to herald.toml and fill in your values
#
# Secrets: use $ENV_VAR or ${ENV_VAR} syntax to reference environment variables.
# Herald will expand these at load time. Never hardcode secrets in this file.
#
# Required environment variables for the default backends:
#   DATABRICKS_HOST          — Databricks workspace hostname
#   DATABRICKS_HTTP_PATH     — SQL warehouse HTTP path
#   DATABRICKS_TOKEN         — Databricks personal access token
#   GMAIL_CREDENTIALS_FILE   — Path to Google OAuth credentials JSON
#   GMAIL_TOKEN_FILE         — Path to Google OAuth token JSON

[datasource]
type = "databricks"

[datasource.params]
server_hostname = "$DATABRICKS_HOST"
http_path = "$DATABRICKS_HTTP_PATH"
access_token = "$DATABRICKS_TOKEN"

[delivery]
type = "gmail"

[delivery.params]
credentials_file = "$GMAIL_CREDENTIALS_FILE"
token_file = "$GMAIL_TOKEN_FILE"

[stakeholders.alice]
name = "Alice Smith"
email = "alice@example.com"
cc = ["charlie@example.com", "dana@example.com"]
query = "queries/alice.sql"
markdown = "stakeholders/alice.md"

[stakeholders.bob]
name = "Bob Jones"
email = "bob@example.com"
cc = ["eve@example.com"]
query = "queries/bob.sql"
markdown = "stakeholders/bob.md"
